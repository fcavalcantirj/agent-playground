# Template for deploy/.env.prod — copy and fill in real values.
# deploy/.env.prod itself is gitignored; this file is checked in.
#
# Loaded by compose via:
#   docker compose --env-file deploy/.env.prod -f deploy/docker-compose.prod.yml ... up -d
#
# Two consumers:
#   1. docker-compose.prod.yml substitutes ${POSTGRES_PASSWORD} and
#      ${AP_CHANNEL_MASTER_KEY} into api_server's environment block.
#   2. The same env_file is also mounted INTO the container (env_file: .env.prod)
#      so python code reads os.environ.AP_CHANNEL_MASTER_KEY directly.
#
# Generate POSTGRES_PASSWORD: openssl rand -hex 32
# Generate AP_CHANNEL_MASTER_KEY: openssl rand -base64 32  (32 bytes → 44 chars b64)

POSTGRES_PASSWORD=

# Phase 22-02: 32-byte base64 master key for channel credential encryption.
# MUST be set in production; dev (AP_ENV=dev) falls back to 32 zero bytes.
AP_CHANNEL_MASTER_KEY=

# Phase 22b-04: sysadmin bypass for event-stream auth (D-15).
# Per-laptop / per-deploy state; NEVER commit the real value.
# Generate: openssl rand -hex 32
AP_SYSADMIN_TOKEN=

# Phase 22c: Google OAuth. Register at https://console.cloud.google.com/apis/credentials
# Callback must match exactly (http://localhost:8000 for dev, https://... for prod).
AP_OAUTH_GOOGLE_CLIENT_ID=
AP_OAUTH_GOOGLE_CLIENT_SECRET=
AP_OAUTH_GOOGLE_REDIRECT_URI=http://localhost:8000/v1/auth/google/callback

# Phase 22c: GitHub OAuth. Register at https://github.com/settings/developers (OAuth Apps → New).
# Scopes requested at authorize time: read:user user:email (needed for email when private).
# No test-users mode — any GitHub user can sign in once the app is registered.
AP_OAUTH_GITHUB_CLIENT_ID=
AP_OAUTH_GITHUB_CLIENT_SECRET=
AP_OAUTH_GITHUB_REDIRECT_URI=http://localhost:8000/v1/auth/github/callback

# --- Phase 22c: Starlette SessionMiddleware signing secret ---
# authlib's OAuth flow stores the CSRF state token inside request.session
# (Starlette's built-in signed-cookie session). AP_OAUTH_STATE_SECRET is
# the signing key for the ap_oauth_state cookie (10-minute TTL; carries the
# state nonce between /v1/auth/<provider> authorize-redirect and
# /v1/auth/<provider>/callback).
#
# REQUIRED in production. In dev (AP_ENV=dev) the code falls back to a
# fixed dev-only placeholder so local tests boot without ops setup.
#
# Generate: openssl rand -hex 32
AP_OAUTH_STATE_SECRET=

# Phase 22c-09: post-OAuth redirect target. The API issues 302s to
# /dashboard and /login?error=... after the OAuth callback completes.
# Without this var the API falls back to http://localhost:3000 — fine
# for dev, BROKEN in prod (users would land on a dead URL after sign-in).
# Set this to the public-facing frontend origin (no trailing slash).
AP_FRONTEND_BASE_URL=http://localhost:3000
