# Agent Playground — environment variables
# Copy this file to `.env` and fill in values for your environment.

# === Go API ===
DATABASE_URL=postgres://temporal:temporal@localhost:5432/agent_playground?sslmode=disable
REDIS_URL=redis://localhost:6379
API_PORT=8080
LOG_LEVEL=info

# === Dev Mode ===
# When AP_DEV_MODE=true, the dev-only auth stub (POST /api/dev/login) is
# enabled and the API accepts signed session cookies from the dev flow.
# MUST be false in production.
AP_DEV_MODE=true
AP_SESSION_SECRET=change-me-to-at-least-32-characters-long-secret

# === Temporal ===
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default

# === Next.js ===
NEXT_PUBLIC_API_URL=http://localhost:8080

# === Phase 2 dev BYOK ===
# Anthropic API key for the dev-mode BYOK injection mechanism.
#
# Phase 2 reads this once at server startup (via session.NewDevEnvSource)
# and injects it into user containers as a tmpfs file at
# /run/secrets/anthropic_key. The ap-base entrypoint reads the file into
# a bash array and passes it to the agent process via
# `env "${AGENT_ENV[@]}" <cmd>` — the key NEVER ends up in PID 1's env.
#
# Phase 3 will replace this env var source with the encrypted pgcrypto
# vault, but the delivery mechanism (host file bind-mount → container
# tmpfs → entrypoint reader) stays exactly the same.
#
# Get a key from: https://console.anthropic.com → Settings → API Keys
# Empty/unset: sessions that require an Anthropic key return 503, and
# scripts/smoke-e2e.sh exits 0 with a SKIPPED message so CI stays green.
AP_DEV_BYOK_KEY=

# === Production Only (not needed for local dev) ===
# TEMPORAL_PG_PASSWORD=<strong-password>
