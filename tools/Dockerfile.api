# syntax=docker/dockerfile:1.7
# Multi-stage build for api_server (Phase 19 FastAPI service).
#
# Stage 1 (build): pulls runtime deps matching api_server/pyproject.toml.
# Stage 2 (runtime): python:3.11-slim + docker CLI + curl + non-root user.
#
# The runner (tools/run_recipe.py) shells out to `docker build` / `docker run`
# against /var/run/docker.sock mounted from the host — see
# deploy/README.md §"Trust Boundary: Docker Socket" (D-08 accepted risk).
#
# DOCKER_GID must match the host socket GID or the non-root apiuser cannot
# access the mounted socket (Pitfall 5). deploy/deploy.sh computes it with
# `stat -c %g /var/run/docker.sock` and passes it as --build-arg.

FROM python:3.11-slim AS build
WORKDIR /src
COPY api_server/pyproject.toml /src/api_server/pyproject.toml
RUN pip install --no-cache-dir --prefix=/install \
      'fastapi==0.136.0' 'uvicorn[standard]>=0.44.0,<0.45' \
      'asyncpg>=0.31.0,<0.32' 'sqlalchemy>=2.0.49,<2.1' \
      'greenlet>=3.0' \
      'alembic>=1.18.4,<1.19' 'pydantic>=2.11' 'pydantic-settings>=2.0' \
      'python-ulid>=3.1.0,<4' 'structlog>=25.5.0,<26' \
      'asgi-correlation-id>=4.3.4,<5' 'ruamel.yaml>=0.17.21' 'jsonschema>=4.23' \
      'pyrage>=1.2' 'cryptography>=42' 'docker>=7.0,<8'
COPY api_server/src /src/api_server/src
COPY api_server/alembic /src/api_server/alembic
COPY api_server/alembic.ini /src/api_server/alembic.ini
COPY tools /src/tools
COPY recipes /src/recipes

FROM python:3.11-slim
ARG DOCKER_GID=999
# docker-cli (not docker.io) — on Debian 13 `docker.io` stopped shipping the
# CLI binary (it only installs dockerd/docker-init/docker-proxy). The api_server
# needs the client to talk to the host daemon via the bind-mounted socket; it
# never runs its own daemon. Using `docker-cli` also avoids creating a docker
# group at install time, so the GID handling below starts from a clean slate.
#
# GID handling: if a group with $DOCKER_GID already exists (e.g., daemon=1),
# add apiuser to that group; otherwise create a fresh `docker` group with the
# right GID. Either way apiuser ends up in a group that owns the host socket.
RUN apt-get update \
 && apt-get install -y --no-install-recommends docker-cli curl ca-certificates \
 && rm -rf /var/lib/apt/lists/* \
 && if ! getent group ${DOCKER_GID} >/dev/null; then groupadd -g ${DOCKER_GID} docker; fi \
 && useradd -m -u 1001 -G "$(getent group ${DOCKER_GID} | cut -d: -f1)" apiuser
COPY --from=build /install /usr/local
COPY --from=build /src /app
WORKDIR /app/api_server
ENV PYTHONPATH=/app/api_server/src:/app/tools
ENV AP_RECIPES_DIR=/app/recipes
USER apiuser
EXPOSE 8000
HEALTHCHECK --interval=15s --timeout=5s --retries=3 --start-period=10s \
    CMD curl -fsS http://localhost:8000/healthz || exit 1
CMD ["uvicorn", "api_server.main:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "2"]
