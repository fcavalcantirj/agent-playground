# Phase 24 — Flutter Foundation env vars
# These are passed via --dart-define at flutter run / flutter test time.
# See mobile/README.md for per-target BASE_URL guidance (D-44).

# Backend API origin. Per-target values:
#   iOS Simulator:    http://localhost:8000
#   Android Emulator: http://10.0.2.2:8000  (NOT localhost — that maps to the emulator)
#   Real device LAN:  http://192.168.X.Y:8000
#   ngrok tunnel:     https://<id>.ngrok-free.app
BASE_URL=http://localhost:8000

# Spike-only: paste from browser DevTools after browser OAuth (D-49). Phase 25 replaces
# this path with native google_sign_in calling POST /v1/auth/google/mobile.
SESSION_ID=

# Spike-only: BYOK OpenRouter key for the 9-step round-trip (D-51).
OPENROUTER_KEY=
